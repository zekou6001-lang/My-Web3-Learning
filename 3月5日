第二十四阶段：掌控时间 —— 交易等待状态 (isPending)
还记得昨天 Wagmi 返回的那个装满数据的“档案袋” {} 吗？
之前，我们只从 useSendTransaction 的档案袋里抽出了 sendTransaction（发射按钮）。但其实，Wagmi 在这个袋子里还极其贴心地为你准备了一个**“状态监控灯”**，它叫 isPending。
💡 isPending 的魔
isPending 是一个开关（Boolean），它的值只能是 true 或 false。
当你还没点按钮时，它是 false。
当你点下按钮，小狐狸钱包弹出来让你确认，直到转账发送到网络上的这段时间，Wagmi 会自动把它变成 true！
发送结束后，它又会自动变回 false。

防手抖的安全转账台
为转账控制台加上这道“安全锁”！
任务步骤：
在抽出 sendTransaction 的同时，把 isPending 也一起从档案袋里抽出来。
在底部的 <button> 标签里，找到 disabled 插槽，把 isPending 填进去锁死按钮。
在按钮的文字区域，使用 {} 打开任意门，写一个“变脸魔法”：如果 isPending 为真，显示 "请在钱包确认..."；如果为假，显示 "立刻发送！"。

代码：
// 引入 React 的记忆盒子魔法
import { useState } from 'react';
// 引入 Wagmi 的转账机器
import { useSendTransaction } from 'wagmi';
// 引入单位翻译官
import { parseEther } from 'viem';

function SafeTransferConsole() {
  // 1. useState: 造一个名叫 amount 的盒子来记住用户输入的数字，初始值为空字符串 ""。
  //    setAmount 是用来修改这个数字的专属遥控器。
  const [amount, setAmount] = useState("");

  // 2. useSendTransaction: 从 Wagmi 的转账机器中抽出两样东西：
  //    sendTransaction (发射按钮) 和 isPending (一个状态灯：如果是 true 说明正在转账中)。
  const { sendTransaction, isPending } = useSendTransaction();

  // 3. executeTransfer: 我们自己造的执行发射的机器，只在用户点击发送时触发。
  function executeTransfer () {
    // 4. 按下 Wagmi 的发射按钮，并交出一个包含转账信息的档案袋 {}。
    sendTransaction({
      // 5. to: 告诉以太坊网络你要把钱打给哪个地址。
      to: "0x9999999999999999999999999999999999999999",
      // 6. value: 把用户输入的 amount 盒子里的文字，用翻译官翻译成区块链认识的天文数字。
      value: parseEther(amount)
    });
  }

  // 7. return: 开始画出网页的集装箱大纸箱。
  return (
    <div>
      {/* 8. 画一个二级标题 */}
      <h2>安全转账控制台</h2>
      
      {/* 9. 画一个输入框 */}
      <input
        // 10. type: 告诉网页这是一个可以输入普通文字的框。
        type="text"
        // 11. 【双向绑定剑刃一】：输入框里显示的文字，必须和 amount 盒子里的数据严格一致。
        value={amount}
        // 12. 【双向绑定剑刃二】：每当用户敲击键盘 (e)，就立刻按遥控器 (setAmount) 把新字存进盒子里。
        onChange={(e) => setAmount(e.target.value)}
        // 13. placeholder: 用户还没打字时，显示的灰色提示文字。
        placeholder="输入的转账数量"
      />
      
      {/* 14. 画一个发送按钮 */}
      <button
        // 15. onClick: 当按钮被点击时，启动上方的 executeTransfer 发射机器。
        onClick={executeTransfer}
        // 16. disabled【安全锁】：把 isPending 状态灯插进来。转账中为 true，按钮立刻变灰不可点。
        disabled={isPending}
      >
        {/* 17. 【变脸魔法】：打开任意门 {} 判断：isPending 是真的吗？
                如果是 (true)，显示 "请在钱包确认..."；
                否则 (false)，显示 "立刻发送！" */}
        {isPending ? "请在钱包确认..." : "立刻发送！"}
      </button>
    </div>
  ); 
}

